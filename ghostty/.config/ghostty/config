# Use zsh regardless of system default shell
command = zsh

# Theme colors - managed by theme-set (symlink)
config-file = ?"~/.config/ghostty/theme.conf"

background-opacity = 1
font-family = JetBrainsMono Nerd Font
font-size = 14
keybind = shift+enter=text:\n
keybind = super+left=text:\x1bOH

# Split appearance
unfocused-split-opacity = 0.5

# Hide macOS title bar (tmux status bar makes it redundant)
macos-titlebar-style = hidden
window-padding-x = 4
window-padding-y = 4

# Disable paste protection warning
clipboard-paste-protection = false

# Enable copy on highlight
copy-on-select = clipboard
mouse-hide-while-typing = true

# Enable desktop notifs
desktop-notifications = true

