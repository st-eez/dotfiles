# Gruvbox Dark Hard theme for btop
# Managed by theme-set - do not edit manually

# Main
theme[main_bg]=""
theme[main_fg]="#ebdbb2"
theme[title]="#ebdbb2"
theme[hi_fg]="#83a598"
theme[selected_bg]="#282828"
theme[selected_fg]="#ebdbb2"
theme[inactive_fg]="#928374"
theme[graph_text]="#928374"
theme[proc_misc]="#b8bb26"

# Box outlines
theme[cpu_box]="#b8bb26"
theme[mem_box]="#d3869b"
theme[net_box]="#8ec07c"
theme[proc_box]="#83a598"
theme[div_line]="#928374"

# Temperature: green -> yellow -> red
theme[temp_start]="#b8bb26"
theme[temp_mid]="#fabd2f"
theme[temp_end]="#fb4934"

# CPU: green -> yellow -> red
theme[cpu_start]="#b8bb26"
theme[cpu_mid]="#fabd2f"
theme[cpu_end]="#fb4934"

# Mem/Disk used: red -> orange (warm = consumption)
theme[used_start]="#fe8019"
theme[used_mid]=""
theme[used_end]="#fb4934"

# Mem/Disk available: green -> cyan (cool = headroom)
theme[available_start]="#b8bb26"
theme[available_mid]=""
theme[available_end]="#8ec07c"

# Mem/Disk free: blue -> cyan
theme[free_start]="#83a598"
theme[free_mid]=""
theme[free_end]="#8ec07c"

# Mem/Disk cached: magenta -> blue
theme[cached_start]="#d3869b"
theme[cached_mid]=""
theme[cached_end]="#83a598"

# Download: cyan -> blue
theme[download_start]="#8ec07c"
theme[download_mid]=""
theme[download_end]="#83a598"

# Upload: orange -> red
theme[upload_start]="#fe8019"
theme[upload_mid]=""
theme[upload_end]="#fb4934"

# Process: green -> orange -> red
theme[process_start]="#b8bb26"
theme[process_mid]="#fe8019"
theme[process_end]="#fb4934"
