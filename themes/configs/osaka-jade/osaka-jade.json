{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "darkBg0": "#111c18",
    "darkBg1": "#1a2520",
    "darkBg2": "#23372b",
    "darkBg3": "#3d4a44",
    "darkFg0": "#c1c497",
    "darkFg1": "#9aa88a",
    "darkGray": "#53685b",
    "darkRed": "#ff5345",
    "darkGreen": "#549e6a",
    "darkYellow": "#459451",
    "darkBlue": "#509475",
    "darkMagenta": "#d2689c",
    "darkCyan": "#2dd5b7",
    "darkWhite": "#f6f5dd",
    "darkRedBright": "#db9f9c",
    "darkGreenBright": "#63b07a",
    "darkYellowBright": "#e5c736",
    "darkBlueBright": "#acd4cf",
    "darkMagentaBright": "#75bbb3",
    "darkCyanBright": "#8cd3cb",
    "lightBg0": "#f6f5dd",
    "lightBg1": "#e8e7cc",
    "lightBg2": "#d5d4b8",
    "lightBg3": "#a8a78c",
    "lightFg0": "#111c18",
    "lightFg1": "#1a2520",
    "lightGray": "#53685b",
    "lightRed": "#c7392d",
    "lightGreen": "#3d7a52",
