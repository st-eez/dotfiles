    "markdownImageText": {
      "dark": "darkGreen",
      "light": "lightGreen"
    },
    "markdownCodeBlock": {
      "dark": "darkFg0",
      "light": "lightFg0"
    },
    "syntaxComment": {
      "dark": "darkGray",
      "light": "lightGray"
    },
    "syntaxKeyword": {
      "dark": "darkCyan",
      "light": "lightCyan"
    },
    "syntaxFunction": {
      "dark": "darkBlue",
      "light": "lightBlue"
    },
    "syntaxVariable": {
      "dark": "darkFg0",
      "light": "lightFg0"
    },
    "syntaxString": {
      "dark": "darkGreenBright",
      "light": "lightGreen"
    },
    "syntaxNumber": {
      "dark": "darkMagenta",
      "light": "lightMagenta"
    },
    "syntaxType": {
      "dark": "darkGreen",
      "light": "lightGreen"
    },
    "syntaxOperator": {
      "dark": "darkYellow",
      "light": "lightYellow"
    },
    "syntaxPunctuation": {
      "dark": "darkFg0",
      "light": "lightFg0"
    }
