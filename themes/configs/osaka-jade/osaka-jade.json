  "theme": {
    "primary": {
      "dark": "darkCyan",
      "light": "lightCyan"
    },
    "secondary": {
      "dark": "darkMagenta",
      "light": "lightMagenta"
    },
    "accent": {
      "dark": "darkGreen",
      "light": "lightGreen"
    },
    "error": {
      "dark": "darkRed",
      "light": "lightRed"
    },
    "warning": {
      "dark": "darkYellowBright",
      "light": "lightYellow"
    },
    "success": {
      "dark": "darkGreen",
      "light": "lightGreen"
    },
    "info": {
      "dark": "darkCyan",
      "light": "lightCyan"
    },
    "text": {
      "dark": "darkFg0",
      "light": "lightFg0"
    },
    "textMuted": {
      "dark": "darkGray",
      "light": "lightGray"
