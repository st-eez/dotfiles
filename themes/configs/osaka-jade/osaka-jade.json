    "markdownBlockQuote": {
      "dark": "darkGray",
      "light": "lightGray"
    },
    "markdownEmph": {
      "dark": "darkMagenta",
      "light": "lightMagenta"
    },
    "markdownStrong": {
      "dark": "darkFg0",
      "light": "lightFg0"
