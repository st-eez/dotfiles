{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "autoDreamEnabled": true,
  "autoMemoryEnabled": true,
  "autoUpdatesChannel": "latest",
  "effortLevel": "high",
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000",
    "CLAUDE_CODE_NEW_INIT": "1",
    "CLAUDE_CODE_SESSIONEND_HOOKS_TIMEOUT_MS": "5000"
  },
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/steez-permission-state.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/steez-skill-analytics.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Skill"
      },
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/steez-permission-state.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "/Users/stevedimakos/Projects/Personal/ren/hooks/plan-mode-gate.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "EnterPlanMode"
      },
      {
        "hooks": [
          {
            "command": "/Users/stevedimakos/Projects/Personal/ren/hooks/decompose-gate.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "ExitPlanMode"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/steez-permission-state.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/steez-permission-state.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "AskUserQuestion"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/steez-permission-state.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/steez-session-start.sh",
            "type": "command"
          },
          {
            "command": "/Users/stevedimakos/Projects/Personal/ren/hooks/wake.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/steez-permission-state.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/steez-permission-state.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "outputStyle": "default",
  "permissions": {
    "allow": [],
    "ask": [],
    "defaultMode": "auto",
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(chmod 777:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ]
  },
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "$HOME/.claude/statusline.sh",
    "type": "command"
  },
  "syntaxHighlightingDisabled": false,
  "voiceEnabled": true
}
